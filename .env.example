# Canonical site URL for sitemap, Open Graph, and JSON-LD (no trailing slash).
# Set this on Vercel (Production) so robots.txt / sitemap.xml match your Search Console property (e.g. https://jelibon.app).
NEXT_PUBLIC_SITE_URL=https://jelibon.app

# Google Tag Manager container ID (e.g. GTM-XXXXXXX)
NEXT_PUBLIC_GTM_ID=

# Google Search Console — optional override for the HTML-tag token (default is set in `src/constants/index.ts`).
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
