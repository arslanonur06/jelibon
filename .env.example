# Canonical site URL for sitemap, Open Graph, and JSON-LD (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://jelibonmarketing.com

# Google Tag Manager container ID (e.g. GTM-XXXXXXX)
NEXT_PUBLIC_GTM_ID=

# Google Search Console — HTML tag verification content value only (not the full tag)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
