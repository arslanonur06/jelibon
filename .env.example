# Canonical site URL for sitemap, Open Graph, and JSON-LD (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://jelibon.app

# Google Tag Manager container ID (e.g. GTM-XXXXXXX)
NEXT_PUBLIC_GTM_ID=

# Google Search Console — paste ONLY the `content="..."` value (the long token), not the filename.
# Search Console → Ownership verification → "HTML tag": copy the string inside content="...".
# That same string is inside the downloaded .html file. It is NOT the same as `77535185e011a25b` in the filename.
# Sets metadata on the site AND serves https://jelibon.app/google77535185e011a25b.html for the HTML-file method.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
